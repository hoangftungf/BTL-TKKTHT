# ===========================================
# AI-ECOMMERCE ENVIRONMENT CONFIGURATION
# ===========================================

# General Settings
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_HOST=postgres

# Individual Database Names
AUTH_DB_NAME=auth_db
USER_DB_NAME=user_db
PRODUCT_DB_NAME=product_db
CART_DB_NAME=cart_db
ORDER_DB_NAME=order_db
PAYMENT_DB_NAME=payment_db
SHIPPING_DB_NAME=shipping_db
REVIEW_DB_NAME=review_db
NOTIFICATION_DB_NAME=notification_db

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Service URLs (Internal)
API_GATEWAY_URL=http://api-gateway:8000
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
PRODUCT_SERVICE_URL=http://product-service:8003
CART_SERVICE_URL=http://cart-service:8004
ORDER_SERVICE_URL=http://order-service:8005
PAYMENT_SERVICE_URL=http://payment-service:8006
SHIPPING_SERVICE_URL=http://shipping-service:8007
REVIEW_SERVICE_URL=http://review-service:8008
NOTIFICATION_SERVICE_URL=http://notification-service:8009

# AI Services
AI_RECOMMENDATION_URL=http://ai-recommendation:8010
AI_SEARCH_URL=http://ai-search:8011
AI_CHATBOT_URL=http://ai-chatbot:8012
AI_ANALYTICS_URL=http://ai-analytics:8013

# Ollama Configuration (LLM for RAG)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Neo4j Knowledge Graph
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Payment - MoMo
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api

# Payment - VNPay
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# Frontend
REACT_APP_API_URL=http://localhost:8000/api
